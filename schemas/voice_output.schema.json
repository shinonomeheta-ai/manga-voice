{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manga-voice/voice_output/1.0",
  "title": "VoiceOutput",
  "description": "音声エージェント(合成)の出力マニフェスト。生成した音声ファイルの一覧。",
  "type": "object",
  "required": ["version", "clips"],
  "properties": {
    "version": {"const": "1.0"},
    "model_id": {"type": "string", "default": "eleven_v3"},
    "dry_run": {"type": "boolean"},
    "clips": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene", "index", "speaker", "file"],
        "properties": {
          "scene": {"type": "string"},
          "index": {"type": "integer"},
          "speaker": {"type": "string"},
          "voice_id": {"type": "string"},
          "file": {"type": "string", "description": "run_dir 相対の音声パス"}
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "scene": {"type": "string"},
          "file": {"type": "string", "description": "シーン連結/ダイアログ音声"}
        }
      }
    }
  }
}
